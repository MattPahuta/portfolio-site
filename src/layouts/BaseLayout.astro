---
import '../styles/global.css';
const { title = 'Matt Pahuta | Web Developer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh font-sans text-lg bg-slate-50 text-gray-700 dark:bg-gray-900 dark:text-gray-300 scroll-smooth">
    <slot />
  </body>
</html>