---
import '../styles/global.css';
const { title = 'Matt Pahuta | Web Developer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.toggle(
        "dark",
        localStorage.theme === "dark" ||
          (!("theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches),
      );
    </script>
  </head>
  <!-- dark:bg-linear-to-b dark:from-gray-950 dark:to-gray-900 -->
  <body class="min-h-dvh font-sans text-lg text-gray-700 dark:text-gray-300 bg-slate-50 dark:bg-gray-900 scroll-smooth">
    <slot />
  </body>
</html>