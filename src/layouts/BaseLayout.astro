---
import '../styles/global.css';
const { title = 'Matt Pahuta' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh grid gap-12 sm:gap-16 font-sans leading-relaxed text-slate-700 dark:text-gray-300 bg-slate-100 dark:bg-gray-950 scroll-smooth">
    <slot />
  </body>
</html>