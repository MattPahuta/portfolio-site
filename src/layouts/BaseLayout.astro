---
import '../styles/global.css';
const { title = 'Matt Pahuta' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="antialiased font-sans text-lg leading-relaxed grid text-slate-900 dark:text-zinc-200 bg-zinc-50 dark:bg-gray-900 scroll-smooth">
    <slot />
  </body>
</html>