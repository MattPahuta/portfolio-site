---
import skills from "../data/skills-alt.json"
import SkillsBadge from "./SkillsBadge.astro";
---


<ul class="flex gap-4 flex-wrap">
  {
    skills.map((skill) => {
      return (
        <li class="py-4 px-2 size-10 rounded-xl shadow hover:scale-95 transition">
          <SkillsBadge 
            name={skill.name} 
            icon={skill.icon} 
          />
        </li>
      );
    })
  }
</ul>