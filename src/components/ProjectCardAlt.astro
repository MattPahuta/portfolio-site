<article class="group overflow-hidden flex flex-col rounded-lg text-slate-200 bg-neutral-900/80 shadow-lg  md:hover:shadow-sky-500/60 transition duration-500">
  <Image src={images[imagePath]()} alt={imageAltText} class="aspect-[4/3] object-cover w-full  transition duration-300" />
  <div class="p-4 w-full flex flex-col grow space-y-6 bg-neutral-700/60">
    <a href="" class="group-hover:text-sky-500 hover:underline decoration-2 underline-offset-4 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-zinc-50 transition rounded-md">
      <h3 class="text-3xl md:text-2xl font-medium text-zinc-50">
        {title}
      </h3>
    </a>
    <ul class="flex flex-wrap items-center gap-3">
      {techStack.map((tech) => (
        <li>
          <Icon name={tech.icon} role="img" title={tech.name} class="size-6 sm:size-8" focusable="false" aria-hidden="true"
          />
          <span class="sr-only">{tech.name}</span>
        </li>
        )
      )}
    </ul>
    <p class="text-lg leading-relaxed font-light">{description}</p>
    <footer class="flex items-center justify-start gap-x-4 text-base md:text-sm mt-auto">
      <a 
        href={gitHubUrl} 
        aria-label="GitHub project repo" 
        class="group max-w-fit px-3 py-2 space-x-2 rounded-xl inline-flex items-center justify-center gap-2 transition border border-slate-700 hover:bg-slate-700 hover:border-slate-700 focus:border-0 focus-within:ring-2 focus-within:ring-slate-200 focus-within:ring-offset-2 active:bg-neutral-900 focus-within:outline-hidden"
      >
        <Icon name="mdi:github" class="size-5" role="img" />
        Source Code
      </a>
      <a 
        href={liveSiteUrl} 
        aria-label="Live preview" 
        class="group max-w-fit px-3 py-2 space-x-2 rounded-xl inline-flex items-center justify-center gap-2 transition border border-slate-700 hover:bg-slate-700 hover:border-slate-700 focus:border-0 focus-within:ring-2 focus-within:ring-slate-200 focus-within:ring-offset-2 active:bg-neutral-900 focus-within:outline-hidden"
      >
        <Icon name="mdi:external-link" class="size-5" role="img" />
        Live Demo
      </a>
    </footer>
  </div>
</article>