---
import SocialsList from '../components/SocialsList.astro';
import { Image } from 'astro:assets';
import avatar from '../assets/avatar_v1.jpg';

const iconSizeClass= "size-8";
---

<section class="pt-12 px-4 flex items-center justify-center">
  <div class="w-full grid gap-10 md:grid-cols-[60%_1fr] md:col-gap-4">
    <div class="text-center md:text-left">
      <h1 class="mb-3 text-4xl md:text-5xl font-heading font-bold tracking-wide text-gray-950 dark:text-zinc-50">Matt Pahuta</h1>
      <p class="mb-4 md:text-xl font-medium text-teal-700 dark:text-blue-400/90">Frontend Focused Software Engineer</p>
      <p class="md:text-xl leading-relaxed">Hi there! I love building stuff for the web with React, TailwindCSS, Astro. I thrive on learning new things and turning design ideas into user-friendly, accessible, and inclusive web experiences.</p>
    </div>
    <div class="md:place-self-center">
      <Image src={avatar} alt="Matt Pahuta" class="m-auto size-52 object-cover rounded-full shadow-gray-300 dark:shadow-gray-800 shadow-2xl" />
    </div>
    <div class="md:justify-self-start">
      <SocialsList iconSize={iconSizeClass} />
    </div>
  </div>
</section>