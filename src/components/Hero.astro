---
import SocialsList from '../components/SocialsList.astro';
import { Image } from 'astro:assets';
import avatar from '../assets/avatar_v1.jpg';

const iconSizeClass= "size-8";
---

<section class="pt-12 sm:pt-20 px-4 flex items-center justify-center">
  <div class="w-full grid gap-10 md:grid-cols-[60%_1fr] md:gap-4">
    <div class="text-center md:text-left">
      <h1 class="mb-3 text-4xl md:text-5xl font-heading font-bold text-slate-950 dark:text-zinc-50">
        Hi, I'm<span class="text-blue-900 dark:text-blue-300"> Matt Pahuta</span>.
      </h1>
      <p class="mb-4 md:text-2xl font-medium text-slate-950 dark:text-slate-300">Frontend Focused Web Developer</p>
      <p class="mb-6 md:text-xl leading-relaxed text-pretty">I build responsive web experiences that bridge the gap between code and clarity, crafted with technologies like <span class="text-emerald-900 font-medium dark:text-celadon">React</span>, <span class="text-emerald-900 font-medium dark:text-celadon">Tailwind CSS</span>, and modern <span class="text-emerald-900 font-medium dark:text-celadon">JavaScript</span>, and designed for everyone.</p>
    </div>
    <div class="md:place-self-center">
      <Image src={avatar} alt="Matt Pahuta" class="m-auto size-52 aspect-auto object-cover rounded-full shadow-lg shadow-gray-300 dark:shadow-gray-800 border-4 border-blue-900 dark:border-blue-300" />
    </div>
    <div class="md:justify-self-start">
      <SocialsList iconSize={iconSizeClass} />
    </div>
  </div>
</section>