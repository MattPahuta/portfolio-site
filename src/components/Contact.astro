---
import { Icon } from 'astro-icon/components'
---

<section id="contact" class="pb-5">
  <div class="space-y-8 max-w-lg lg:max-w-4xl mx-auto px-4 sm:px-6">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-16">
      <div class="text-center lg:py-5 lg:text-left">
        <h2 class="mb-2 sm:mb-4 text-3xl md:text-4xl font-ubuntu font-semibold text-slate-900 dark:text-zinc-50 whitespace-nowrap">Let's Work Together</h2>
        <p class="leading-relaxed md:text-xl">Have an idea, a question, or an opportunity? Connect with me via email or LinkedIn.</p>
      </div>
      <div class="flex">
        <ul class="font-ubuntu font-medium flex flex-wrap items-center justify-center start gap-3 md:gap-4">
          <li class="w-full">
            <a 
              href="mailto:mhpahuta@gmail.com" 
              class="group w-full py-2 px-4 inline-flex items-center gap-4 rounded-lg shadow-md sm:shadow-lg bg-white border border-slate-100 dark:border-gray-600 dark:bg-transparent hover:bg-blue-400 dark:hover:bg-blue-600 hover:border-blue-400 dark:hover:border-blue-700 hover:text-neutral-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-500 sm:hover:-translate-y-1.5 transition"
            >
              <div class="p-3 rounded-lg bg-blue-100 dark:bg-gray-800 group-hover:bg-white dark:group-hover:bg-gray-900">
                <Icon name="mail" aria-hidden="true" focusable="false" class="size-5 text-blue-700 dark:text-gray-200" />
              </div>
              <div class="flex flex-col">
                <span class="text-slate-800 dark:text-gray-200 font-semibold group-hover:text-slate-950 dark:group-hover:text-gray-50 transition-colors">Email</span>
                <span class="text-sm text-slate-600 dark:text-gray-400 group-hover:text-slate-950 dark:group-hover:text-gray-200 transition-colors">mhpahuta@gmail.com</span>
              </div>
            </a>
          </li>
          <li class="w-full">
            <a 
              href="https://linkedin.com/in/mattpahuta" 
              target="_blank"
              rel="noreferrer noopener"
              class="group w-full py-2 px-4 inline-flex items-center gap-4 rounded-lg shadow-md sm:shadow-lg bg-white border border-slate-100 dark:border-gray-600 dark:bg-transparent hover:bg-blue-400 dark:hover:bg-blue-600 hover:border-blue-400 dark:hover:border-blue-700 hover:text-neutral-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-500 sm:hover:-translate-y-1.5 transition"
            >
              <div class="p-3 rounded-lg bg-blue-100 dark:bg-gray-800 group-hover:bg-white dark:group-hover:bg-gray-900">
                <Icon name="linkedin" aria-hidden="true" focusable="false" class="size-5 text-blue-700 dark:text-gray-200" />
              </div>
              <div class="flex flex-col">
                <span class="text-slate-800 dark:text-gray-200 font-semibold group-hover:text-slate-950 dark:group-hover:text-gray-50 transition-colors">LinkedIn</span>
                <span class="text-sm text-slate-600 dark:text-gray-400 group-hover:text-slate-950 dark:group-hover:text-gray-200 transition-colors">/in/MattPahuta</span>
              </div>
            </a>
          </li>
          <!-- href, iconName, iconSize, title, handle -->
          <li class="w-full">
            <a 
              href="https://github.com/MattPahuta" 
              target="_blank"
              rel="noreferrer noopener"
              class="group w-full py-2 px-4 inline-flex items-center gap-4 rounded-lg shadow-md sm:shadow-lg bg-white border border-slate-100 dark:border-gray-600 dark:bg-transparent hover:bg-blue-400 dark:hover:bg-indigo-600 hover:border-blue-400 dark:hover:border-indigo-600 hover:text-neutral-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-indigo-500 transition"
            >
              <div class="p-3 rounded-lg bg-blue-100 dark:bg-gray-800 group-hover:bg-white dark:group-hover:bg-gray-900">
                <Icon name="github" aria-hidden="true" focusable="false" class="size-5 text-blue-700 dark:text-gray-200 dark:group-hover:text-indigo-400" />
              </div>
              <div class="flex flex-col">
                <span class="text-slate-800 dark:text-gray-200 font-semibold group-hover:text-slate-950 dark:group-hover:text-gray-50 transition-colors">GitHub</span>
                <span class="text-sm text-slate-600 dark:text-gray-400 group-hover:text-slate-950 dark:group-hover:text-gray-200 transition-colors">@MattPahuta</span>
              </div>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>  