---
import { Icon } from "astro-icon/components";
const { label, icon, color, size, href } = Astro.props;
---

<a 
  href=`${href}` 
  target="_blank"
  rel="noreferrer noopener"
  class=`py-2 px-4 inline-flex items-center justify-center gap-2 rounded-lg border-2 border-${color}-500 text-${color}-500 dark:text-slate-200 hover:bg-${color}-500 hover:text-neutral-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-${color}-500 transition-colors`
>
  <Icon name=`${icon}` aria-hidden="true" focusable="false" class=`${size}`` />
  {label}
</a>