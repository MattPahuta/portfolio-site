---
import Nav from "./Nav.astro";
import NavAlt from "./NavAlt.astro";
import SocialsList from '../components/SocialsList.astro';
import ContactSocialList from "./ContactSocialList.astro";
import { Image } from 'astro:assets';
import avatar from '../assets/avatar_v1.jpg';

import { Icon } from "astro-icon/components";

---

<!-- semantic element for bg-color and block padding -->
<header class="min-h-dvh flex flex-col bg-radial from-slate-100 to-slate-50 dark:bg-linear-to-b dark:from-gray-950 dark:to-gray-800">
  <!-- nav wrapper -->
   <div class="fixed top-0 z-50 flex-none mx-auto w-full bg-slate-50/70 dark:bg-gray-950/40 backdrop-blur-md border-b-2 border-slate-200 dark:border-b-0">
    <!-- nav inner -->
     <NavAlt />
   </div>

  <!-- wrapper element for max-width (inline-size), mx-auto, inline padding-->
  <div class="mx-auto max-w-5xl px-4 grow flex items-center">
    <!-- hero card - layout div for flex or grid styles -->
     <div class="py-8 sm:px-12 sm:py-16 font-light grid lg:grid-cols-[33%_1fr] gap-12 lg:gap-8 items-center justify-items-center md:justify-items-start text-lg sm:text-xl text-center sm:bg-white dark:bg-transparent sm:shadow-xl dark:shadow-none sm:border border-slate-200 rounded-2xl dark:border-0 md:dark:border md:dark:shadow-xl dark:border-gray-700">
      <!-- grid item -->
      <Image src={avatar} alt="Headshot of Matt Pahuta" class="size-44 sm:size-56 aspect-auto object-cover rounded-full shadow-lg shadow-gray-300 dark:shadow-gray-900" />
      <!-- grid item -->
      <div class="max-w-[540px] space-y-8 text-center sm:text-left">
        <h1 class="mb-2.5 font-bold text-3xl md:text-5xl">
          <span class="text-xl font-medium text-slate-600 dark:text-gray-300 block">Hi there, I'm</span>
          <span class="text-neutral-950 dark:text-zinc-50">Matt Pahuta</span>
        </h1>
        <p class="text-lg md:text-xl font-mono font-medium text-slate-600 dark:text-gray-300">
          Full-Stack Developer
        </p>
        <p class="text-pretty md:col-span-2">I build web experiences that don't just work, they make sense. Powered by <span class="font-medium underline underline-offset-4 decoration-2 decoration-cyan-500">React</span>, <span class="font-medium underline underline-offset-4 decoration-2 decoration-indigo-500">Tailwind CSS</span>, and modern <span class="font-medium underline underline-offset-4 decoration-2 decoration-orange-400">JavaScript</span>, grounded in accessibility from the start.</p>

        <!-- contact me socials -->
        <div class="sm:pt-5 font-mono font-medium">
          <ContactSocialList />
        </div>
       </div>
     </div>
  </div>
</header>