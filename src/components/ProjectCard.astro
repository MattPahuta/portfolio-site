---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { Icon } from "astro-icon/components";
// import project1 from '../assets/images/projects/frontend-quiz.png';

interface TechItem {
  name: string;
  icon: string;
}

interface Props {
  title: string;
  description: string;
  imagePath: string;
  imageAltText: string;
  techStack: TechItem[];
  gitHubUrl: string;
  liveSiteUrl: string;
}

const { title, description, imagePath, imageAltText, techStack, gitHubUrl, liveSiteUrl } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/projects/*.{jpeg,jpg,png,gif}');

if (!images[imagePath]) throw new Error(`"${imagePath}" does not exist in glob: "src/assets/projects/*.{jpeg,jpg,png,gif}"`);
---
<!-- ToDo: Check screen reader announcement with project cards -->

<!-- 
 bg-white dark:bg-black/20 sm:rounded-xl shadow-md dark:shadow-lg sm:border sm:border-transparent dark:sm:border-slate-800 sm:hover:border-indigo-200/70 dark:sm:hover:border-indigo-500/30 sm:hover:bg-indigo-50/40 dark:sm:hover:bg-indigo-950/20 dark:sm:hover:shadow-indigo-500/20
-->

<article class="flex flex-col gap-5 md:gap-6 sm:flex-row p-4 sm:p-6 bg-white dark:bg-slate-950/80 rounded-lg sm:rounded-xl shadow-md dark:shadow-lg sm:border sm:border-transparent dark:sm:border-slate-700 sm:hover:border-blue-200/70 dark:sm:hover:border-blue-500/30 sm:hover:bg-blue-50/40 dark:sm:hover:bg-blue-950/20 hover:shadow-xl dark:sm:hover:shadow-blue-500/20 sm:hover:-translate-y-0.5 transition duration-300">
  <div class="w-full overflow-hidden grid content-center">
    <Image src={images[imagePath]()} alt={imageAltText} class="object-cover w-full rounded-lg sm:rounded-xl aspect-[4/3]" />
  </div>
  <div class="w-full flex flex-col grow space-y-6">
    <a href="" class="group hover:text-blue-400 hover:underline decoration-2 underline-offset-4 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-zinc-50 transition rounded-md">
      <h3 class="text-2xl font-medium dark:text-zinc-50">
        {title}
      </h3>
    </a>
    <ul class="flex flex-wrap items-center gap-3">
      {techStack.map((tech) => (
        <li>
          <Icon name={tech.icon} role="img" title={tech.name} class="size-6 sm:size-8" focusable="false" aria-hidden="true"
          />
          <span class="sr-only">{tech.name}</span>
        </li>
        )
      )}
    </ul>
    <p class="md:text-lg leading-relaxed font-light">{description}</p>
    <footer class="flex items-center justify-start gap-x-4 text-xs md:text-sm mt-auto">
      <a 
        href={gitHubUrl} 
        aria-label="GitHub project repo" 
        class="group max-w-fit px-3 py-2 space-x-2 rounded-xl inline-flex items-center justify-center gap-2 transition dark:border shadow-sm bg-gray-100 hover:bg-white dark:bg-transparent border-slate-700 dark:hover:bg-slate-700 dark:sm:hover:bg-slate-950 hover:border-slate-950 hover:shadow-md focus:border-0 focus-within:ring-2 focus-within:ring-slate-200 focus-within:ring-offset-2 active:bg-slate-950/40 focus-within:outline-hidden"
      >
        <Icon name="mdi:github" class="size-5" role="img" />
        Source Code
      </a>
      <a 
        href={liveSiteUrl} 
        aria-label="Live preview" 
        class="group max-w-fit px-3 py-2 space-x-2 rounded-xl inline-flex items-center justify-center gap-2 transition dark:border shadow bg-gray-100 hover:bg-white dark:bg-transparent dark:border-slate-700 dark:hover:bg-slate-700 dark:sm:hover:bg-slate-950 hover:border-slate-950 hover:shadow-md focus:border-0 focus-within:ring-2 focus-within:ring-slate-200 focus-within:ring-offset-2 active:bg-slate-950/40 focus-within:outline-hidden"
      >
        <Icon name="mdi:external-link" class="size-5" role="img" />
        Live Demo
      </a>
    </footer>
  </div>
</article>