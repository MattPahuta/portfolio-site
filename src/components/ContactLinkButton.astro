---
import { Icon } from "astro-icon/components";
const { label, handle, href, iconName, iconSize } = Astro.props;
---
<a 
  href=`${href}`
  target="_blank"
  rel="noreferrer noopener"
  class="group w-full py-2 px-4 inline-flex items-center gap-4 rounded-lg bg-white border-2 border-blue-200 dark:border-gray-600 dark:bg-transparent hover:bg-blue-400 dark:hover:bg-indigo-600 hover:border-blue-400 dark:hover:border-indigo-600 hover:text-neutral-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-400 dark:focus-visible:outline-indigo-500 transition"
>
  <div class="p-3 rounded-lg bg-blue-100 dark:bg-gray-800 group-hover:bg-white dark:group-hover:bg-gray-900">
    <Icon name=`${iconName}` aria-hidden="true" focusable="false" class=`${iconSize} text-blue-600 dark:text-gray-200 dark:group-hover:text-indigo-400` />
  </div>
  <div class="flex flex-col">
    <span class="text-slate-800 dark:text-gray-200 font-semibold group-hover:text-slate-950 dark:group-hover:text-gray-50 transition-colors">{label}</span>
    <span class="text-sm text-slate-600 dark:text-gray-400 group-hover:text-slate-950 dark:group-hover:text-gray-200 transition-colors">{handle}</span>
  </div>
</a>