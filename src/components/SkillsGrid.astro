---
import skills from "../data/skills.json"
import SkillsBadge from "./SkillsBadge.astro";
---

<!-- <ul class="flex gap-4 flex-wrap"> -->
<ul class="grid grid-cols-2 gap-4">
{
    skills.map((skill) => {
      return (
        <li class="py-4 px-2 flex gap-4 items-center bg-slate-100 dark:bg-gray-950 dark:border dark:border-slate-700 rounded-xl shadow hover:scale-95 transition">
          <SkillsBadge 
            name={skill.name} 
            icon={skill.icon} 
          />
          <span class="font-mono text-sm font-semibold text-slate-600 dark:text-gray-400">
            {skill.name}
          </span>
        </li>
      );
    })
  }
</ul>
